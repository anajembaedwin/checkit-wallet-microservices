{
  "name": "checkit-wallet-microservices",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "1.0.0",
  "scripts": {
    "dev:user": "npm run start:dev --workspace=apps/user-service",
    "dev:wallet": "npm run start:dev --workspace=apps/wallet-service",
    "build": "npm run build --workspaces",
    "test:user": "npm run test --workspace=apps/user-service -- --runInBand",
    "test:wallet": "npm run test --workspace=apps/wallet-service -- --runInBand",
    "test:integration": "npm run build --workspace=apps/user-service && npm run build --workspace=apps/wallet-service && npx jest --config ./integration/jest.integration.json --runInBand",
    "prisma:generate": "npx prisma generate --schema=packages/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=packages/prisma/schema.prisma",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/microservices": "^11.1.17",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "prisma": "^7.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
